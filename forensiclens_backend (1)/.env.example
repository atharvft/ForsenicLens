# Application Configuration
APP_NAME=ForensicLens AI Backend
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration (Update with your Next.js frontend URL)
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
CORS_CREDENTIALS=True
CORS_METHODS=*
CORS_HEADERS=*

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://forensiclens:password123@localhost:5432/forensiclens_db
DATABASE_ECHO=False

# JWT Authentication
# IMPORTANT: Change this to a strong random secret key in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage Configuration
UPLOAD_DIR=uploads/original
PROCESSED_DIR=uploads/processed
MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

# AI Model Configuration
USE_GPU=True
ANOMALY_MODEL_PATH=models/anomaly_detector
UPSCALING_MODEL_PATH=models/upscaler
BATCH_SIZE=4

# ngrok Configuration (for Google Colab deployment)
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=your-ngrok-auth-token-here
NGROK_ENABLED=False

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
