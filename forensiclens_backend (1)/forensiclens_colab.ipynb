    "print(\"✅ Database initialized (or skipped)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Start ngrok Tunnel\n",
    "\n",
    "This exposes your Colab backend to the internet so your frontend can connect."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pyngrok import ngrok, conf\n",
    "\n",
    "# Set ngrok auth token\n",
    "ngrok_token = os.environ.get('NGROK_AUTH_TOKEN')\n",
    "if ngrok_token and ngrok_token != 'your-ngrok-auth-token-here':\n",
    "    conf.get_default().auth_token = ngrok_token\n",
    "    \n",
    "    # Start tunnel\n",
    "    public_url = ngrok.connect(8000)\n",
    "    \n",
    "    print(\"\\n" + \"=\" * 60)\n",
    "    print(\"🚀 ForensicLens AI Backend is now accessible at:\")\n",
    "    print(f\"\\n   {public_url}\\n\")\n",
    "    print(\"Copy this URL and use it in your Next.js frontend!\")\n",
    "    print(\"=\" * 60 + \"\\n\")\n",
    "    \n",
    "    # Save URL to file for easy access\n",
    "    with open('ngrok_url.txt', 'w') as f:\n",
    "        f.write(str(public_url))\n",
    "else:\n",
    "    print(\"⚠️ Please set your NGROK_AUTH_TOKEN in the environment variables cell!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Start FastAPI Server\n",
    "\n",
    "This starts the backend server. Keep this cell running!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import uvicorn\n",
    "from app.main import app\n",
    "\n",
    "print(\"🚀 Starting ForensicLens AI Backend...\\n\")\n",
    "\n",
    "# Run the server\n",
    "uvicorn.run(\n",
    "    app,\n",
    "    host=\"0.0.0.0\",\n",
    "    port=8000,\n",
    "    log_level=\"info\"\n",
    ")\n",
    "\n",
    "# Note: This cell will keep running. To stop the server,\n",
    "# interrupt the cell execution."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Test the API\n",
    "\n",
    "Open a new cell or use your browser to test the API."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "\n",
    "# Read ngrok URL\n",
    "with open('ngrok_url.txt', 'r') as f:\n",
    "    base_url = f.read().strip()\n",
    "\n",
    "# Test health endpoint\n",
    "response = requests.get(f\"{base_url}/api/v1/health/health\")\n",
    "print(\"Health Check:\", response.json())\n",
    "\n",
    "# Test system status\n",
    "response = requests.get(f\"{base_url}/api/v1/health/status\")\n",
    "print(\"\\nSystem Status:\", response.json())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📝 Usage Notes\n",
    "\n",
    "**Important Tips:**\n",
    "\n",
    "1. **Keep the server cell running** - The backend will stop if you interrupt that cell\n",
    "2. **Save the ngrok URL** - You'll need it for your Next.js frontend\n",
    "3. **GPU Runtime** - Make sure you selected GPU runtime for optimal performance\n",
    "4. **Session Timeout** - Colab sessions timeout after inactivity. You'll need to rerun the notebook.\n",
    "5. **Free Tier Limits** - Free Colab has usage limits. Consider Colab Pro for longer sessions.\n",
    "\n",
    "**API Documentation:**\n",
    "- Swagger UI: `{ngrok_url}/docs`\n",
    "- ReDoc: `{ngrok_url}/redoc`\n",
    "\n",
    "**Common Commands:**\n",
    "```python\n",
    "# View ngrok URL\n",
    "!cat ngrok_url.txt\n",
    "\n",
    "# Check GPU usage\n",
    "!nvidia-smi\n",
    "\n",
    "# View logs\n",
    "# Check the server cell output\n",
    "```"
   ]
  }
