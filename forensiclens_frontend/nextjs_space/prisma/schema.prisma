generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/forensiclens_frontend/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  password       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  photos         Photo[]
}

model Photo {
  id                    String       @id @default(cuid())
  userId                String
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalCloudPath     String?
  originalUrl           String?
  isOriginalPublic      Boolean      @default(true)
  anomalyCloudPath      String?
  anomalyUrl            String?
  isAnomalyPublic       Boolean      @default(true)
  upscaledCloudPath     String?
  upscaledUrl           String?
  isUpscaledPublic      Boolean      @default(true)
  fileName              String
  fileSize              Int?
  mimeType              String?
  status                PhotoStatus  @default(UPLOADED)
  anomalyStatus         ProcessStatus @default(PENDING)
  upscaleStatus         ProcessStatus @default(PENDING)
  anomalyData           Json?
  upscaleData           Json?
  backendPhotoId        String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}

enum PhotoStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum ProcessStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
