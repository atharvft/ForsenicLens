# ForensicLens AI - Environment Configuration
# Copy this file to .env and update the values

# Your FastAPI backend URL (ngrok URL)
# Replace with your actual ngrok URL when running the backend
NEXT_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.app

# Database URL (auto-generated)
# DATABASE_URL=postgresql://...

# NextAuth Secret (auto-generated)
# NEXTAUTH_SECRET=your-secret

# AWS S3 (auto-generated)
# AWS_PROFILE=hosted_storage
# AWS_REGION=us-west-2
# AWS_BUCKET_NAME=your-bucket
# AWS_FOLDER_PREFIX=your-prefix/
